<?xml version="1.0" encoding="utf-8"?>
<!--
    Debug-only override. Lives in src/debug/res so it never ships in release.

    - Allows user-installed CAs so Charles / Proxyman / mitmproxy can inspect
      Supabase + Razorpay traffic during engineering.
    - Keeps TLS pins in place for release builds (defined in src/main/res/xml).

    Android's merge rule picks the debug variant resource over the main one for
    this file in debug builds. Release builds don't see this file at all.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <!--
        Nesting the user-CA anchor inside <debug-overrides> tells the
        framework it MUST only activate when android:debuggable=true.
        Defense-in-depth on top of the src/debug variant scoping (which
        already keeps this file out of release builds) so a build-config
        slip-up that included this file in release still wouldn't ship
        user-CA trust to end users.
    -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
