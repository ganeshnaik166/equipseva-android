<?xml version="1.0" encoding="utf-8"?>
<!--
    Pre-Android-12 backup rules. App sets android:allowBackup="false" so this file is a
    belt-and-suspenders guarantee: if backups are ever re-enabled upstream (e.g. OEM skin
    with its own policy), nothing sensitive is eligible.
-->
<full-backup-content>
    <exclude domain="root" path="." />
    <exclude domain="file" path="." />
    <exclude domain="database" path="." />
    <exclude domain="sharedpref" path="." />
    <exclude domain="external" path="." />
</full-backup-content>
