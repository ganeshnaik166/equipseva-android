# Copy to `local.properties` and fill in real values. NEVER commit the real file.

# Android SDK location (set automatically by Android Studio on first sync)
sdk.dir=/Users/<you>/Library/Android/sdk

# Supabase (required — auth + data layer won't work without these)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-public-key>

# Sentry (optional in dev — leave blank to skip Sentry init)
SENTRY_DSN=

# Razorpay (required for AMC subscription + repair-job escrow flows)
RAZORPAY_KEY=

# Google Sign-in: WEB client ID from Firebase / Google Cloud Console
# (NOT the Android client ID — Credential Manager + Supabase verify-id-token both want the WEB type)
GOOGLE_WEB_CLIENT_ID=

# Google Maps API key — required for the repair-feed map, the
# job-detail site map, the engineer location-share screen, and the
# founder engineer-zone map. Project must have Maps SDK for Android
# enabled.
MAPS_API_KEY=

# Anti-tamper: comma-separated SHA-256 base64 fingerprints of every
# legitimate signing cert. SignatureVerifier compares the running APK
# against any entry; mismatch => Verdict.Tampered.
#   - Upload key (extract from app/equipseva-upload.jks)
#   - Play App Signing key (paste from Play Console after first AAB)
# Leave blank locally — the verifier returns Verdict.Unknown and
# skips enforcement when the list is empty. See
# docs/security/LAUNCH_INFRA.md §3 for the extraction recipe.
EXPECTED_CERT_SHA256=
